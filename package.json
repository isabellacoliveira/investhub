{
  "name": "investhub-mf-demo",
  "version": "1.0.0",
  "scripts": {
    "start:shell": "cd projects/shell && ng serve shell --port 4200 --serve-path / --configuration=development",
    "start:portfolio": "cd projects/portfolio && ng serve portfolio --port 4201 --serve-path / --configuration=development",
    "start:products": "cd projects/products && ng serve products --port 4202 --serve-path / --configuration=development",
    "start:all": "concurrently \"npm run start:shell\" \"npm run start:portfolio\" \"npm run start:products\"",
    "stop:all": "taskkill /F /IM node.exe",
    "demo:outage:portfolio": "taskkill /F /IM \"ng serve portfolio*\"",
    "demo:outage:products": "taskkill /F /IM \"ng serve products*\""
  },
  "devDependencies": {
    "@angular-architects/module-federation": "^21.2.1",
    "concurrently": "^8.2.2",
    "ngx-build-plus": "^20.0.0"
  },
  "dependencies": {
    "@angular/common": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-server": "^21.2.4",
    "@angular/router": "^21.2.4",
    "@angular/ssr": "^21.2.2",
    "zone.js": "^0.16.1"
  }
}
